# Project config — real values live here, never committed
config.env

# Env files — never commit secrets
.env
.env.local
.env.*.local
.env.prod
.env.staging
.env.production
*.env.*

# Terraform variable values — generated by scripts/configure.py
terraform.tfvars
terraform.tfvars.json

# Node
node_modules/
npm-debug.log*

# React build output
client/build/

# Terraform state — use remote backend (S3 + DynamoDB)
*.tfstate
*.tfstate.*
*.tfstate.backup
.terraform/
tfplan
# NOTE: .terraform.lock.hcl is intentionally NOT ignored — commit it like package-lock.json

# K8s secrets — use Sealed Secrets or External Secrets Operator
k8s/secrets/db-secret.yaml

# SSH private keys — never commit key material
id_*
*.pem
*.key
*.p12
*.pfx

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
kubectl.exe

# Claude Code — local AI assistant config (not team config)
.claude/
